# Extract concept
get_concept <- function(x){
strsplit(x, "_")[[1]][2]
}
# Create session
session <- handle("https://mycsg.in")
# LOGIN
POST(
url = "https://mycsg.in/login.php?next=%2Findex.php",
handle = session,
body = list(
username = "Ravi",
password = "Rochana@07"
),
encode = "form"
)
# Download files
for(lesson in lessons){
concept <- get_concept(lesson)
# Create folder
folder_path <- file.path(
main_path,
lesson
)
dir.create(
folder_path,
recursive = TRUE,
showWarnings = FALSE
)
# FILE LINKS
r_program_url <- paste0(
"https://mycsg.in/lesson_download.php?lesson=",
lesson,
"&content=r_program&return=%2Fadam.php%3Farea%3Dadam%26concept%3D",
concept,
"%26lesson%3D",
lesson
)
r_data_url <- paste0(
"https://mycsg.in/lesson_download.php?lesson=",
lesson,
"&content=r_data&return=%2Fadam.php%3Farea%3Dadam%26concept%3D",
concept,
"%26lesson%3D",
lesson
)
# DOWNLOAD R PROGRAM FILE
try({
GET(
url = r_program_url,
handle = session,
write_disk(
file.path(
folder_path,
"R_PROGRAM.zip"
),
overwrite = TRUE
),
progress()
)
cat(
"Downloaded R_PROGRAM:",
lesson,
"\n"
)
}, silent = TRUE)
# DOWNLOAD R DATA FILE
try({
GET(
url = r_data_url,
handle = session,
write_disk(
file.path(
folder_path,
"R_DATA.zip"
),
overwrite = TRUE
),
progress()
)
cat(
"Downloaded R_DATA:",
lesson,
"\n"
)
}, silent = TRUE)
}
